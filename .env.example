# AllSportsApi (https://allsportsapi.com/) — primary live data
# Free: 2 random leagues | European ($74/mo): EPL + 42 leagues | Ultimate ($149/mo): all + live odds
ALLSPORTS_API_KEY=

# SportMonks Football API (https://sportmonks.com/)
# Free: Danish/Scottish | Paid: EPL + all leagues
SPORTMONKS_API_KEY=

# Legacy: API-Football (https://www.api-football.com/)
# Alternative live data source
FOOTBALL_API_KEY=

# The Odds API (https://the-odds-api.com/)
# Used for real betting odds + market edge calculation
ODDS_API_KEY=

# Redis (used in Docker deployment)
REDIS_URL=redis://redis:6379
